<!-- ===== SECTION: COUNTRIES ===== -->
<section class="section section-countries" id="countries">
  <div class="container-site">

    <div class="countries-head">
      <div class="countries-badge">Страны поставки автомобилей в Россию</div>
      <h2 class="h2 countries-title">
        Импорт авто из <span class="text-gradient">Кореи, Китая и США</span>
      </h2>
      <p class="body countries-subtitle">
        Подбираем страну поставки под вашу задачу: выгодная цена, нужная комплектация, сроки доставки и прозрачный расчёт под ключ.
      </p>
    </div>

    {% set countries = [
      {
        slug: 'avto-iz-korei',
        name: 'Кореи',
        label: 'Корея',
        image: 'sections/countries/images/korea.png',
        flag: 'images/korea-flag.svg',
        alt: 'Импорт авто из Кореи',
        accent_icon: '<path d="M8 1.8l1.65 3.35 3.7.54-2.68 2.62.63 3.69L8 10.25 4.7 12l.63-3.69L2.65 5.69l3.7-.54L8 1.8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>',
        accent_label: 'Самый популярный вариант',
        text: 'Проверенные автомобили с прозрачной историей и хорошим состоянием',
        features: ['Прозрачные площадки и отчёты', 'Небольшие пробеги и ликвидные модели', 'Минимальные риски при покупке'],
        cta: 'Подобрать авто из Кореи',
      },
      {
        slug: 'avto-iz-kitaya',
        name: 'Китая',
        label: 'Китай',
        image: 'sections/countries/images/china.png',
        flag: 'images/china-flag.svg',
        alt: 'Импорт авто из Китая',
        accent_icon: '<path d="M8.6 1.7 4.2 8h3l-.8 6.3L11.8 8h-3.1l-.1-6.3z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>',
        accent_label: 'Современные технологии',
        text: 'Новые автомобили, гибриды и электромобили по конкурентной цене',
        features: ['Широкий выбор новых моделей', 'Технологичные комплектации', 'Оптимальные сроки поставки'],
        cta: 'Подобрать авто из Китая',
      },
      {
        slug: 'avto-iz-ssha',
        name: 'США',
        label: 'США',
        image: 'sections/countries/images/usa.png',
        flag: 'images/usa-flag.svg',
        alt: 'Импорт авто из США',
        accent_icon: '<path d="M4.1 5.4c0-1.7 1.4-3.1 3.1-3.1h1.5c1.7 0 3.1 1.4 3.1 3.1S10.4 8.5 8.7 8.5H7.2c-1.7 0-3.1 1.4-3.1 3.1s1.4 3.1 3.1 3.1h1.5c1.7 0 3.1-1.4 3.1-3.1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>',
        accent_label: 'Максимальная экономия',
        text: 'Автомобили с аукционов США с потенциалом максимальной экономии',
        features: ['Аукционы США', 'Большой выбор комплектаций', 'Существенная экономия бюджета'],
        cta: 'Подобрать авто из США',
      },
    ] %}

    <div class="countries-grid">
      {% for country in countries %}
      <article class="countries-card">
        <div class="countries-card__media">
          <img src="{{ url('theme://' ~ country.image) }}" alt="{{ country.alt }}" loading="lazy">
          <img class="countries-card__flag" src="{{ url('theme://' ~ country.flag) }}" alt="">
          <div class="countries-card__accent">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              {{ country.accent_icon|raw }}
            </svg>
            <span>{{ country.accent_label }}</span>
          </div>
        </div>
        <div class="countries-card__body">
          <div class="countries-card__intro">
            <h3 class="countries-card__title">Импорт авто из <span class="text-gradient">{{ country.name }}</span></h3>
            <p class="countries-card__text">{{ country.text }}</p>
          </div>

          <ul class="countries-card__meta">
            {% for feature in country.features %}
            <li class="countries-meta-item">
              <span>{{ feature }}</span>
            </li>
            {% endfor %}
          </ul>

          <a href="#cta" class="countries-card__btn">
            <span>{{ country.cta }}</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="countries-trust">
      <div class="countries-trust__item">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 3l8 3v7c0 5.2-3.5 9.9-8 11-4.5-1.1-8-5.8-8-11V6l8-3z" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        <span>Работаем напрямую с аукционами и дилерами</span>
      </div>
      <div class="countries-trust__item">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="5" y="4" width="18" height="20" rx="2" stroke="currentColor" stroke-width="1.8"/>
          <path d="M9 10h10M9 15h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <span>Считаем полную стоимость до выкупа</span>
      </div>
      <div class="countries-trust__item">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 22l7-7m0 0l3 3 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="13" cy="15" r="8" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        <span>Контролируем каждый этап логистики</span>
      </div>
      <div class="countries-trust__item">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 3l8 3v7c0 5.2-3.5 9.9-8 11-4.5-1.1-8-5.8-8-11V6l8-3z" stroke="currentColor" stroke-width="1.8"/>
          <path d="M10 14l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Прозрачный импорт и юридическая безопасность</span>
      </div>
    </div>

  </div>
</section>
<!-- ===== /SECTION: COUNTRIES ===== -->
